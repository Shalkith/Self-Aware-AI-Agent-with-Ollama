# Example environment configuration for Self-Aware AI Agent
# Copy this to .env and modify as needed

# Ollama Configuration
OLLAMA_URL=http://192.168.99.113:11434
OLLAMA_TIMEOUT=30

# Agent Identity
AGENT_NAME=SelfAwareAI
AGENT_VERSION=1.0.0
AGENT_PERSONALITY=curious and helpful

# Model Configuration
THINKING_MODEL=llama3
VISION_MODEL=llava
CONVERSATION_MODEL=llama3
REASONING_MODEL=mistral
CREATIVITY_MODEL=llama3
SECURITY_MODEL=llama3

# Security Configuration
SECURITY_ENABLED=true
SECURITY_DENY_BY_DEFAULT=true
SECURITY_APPROVAL_TIMEOUT=300
SECURITY_LOG_LEVEL=INFO

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Camera Configuration
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Audio Configuration
AUDIO_RATE=16000
AUDIO_CHUNK=1024
AUDIO_CHANNELS=1

# Memory Configuration
MEMORY_DB_PATH=memory/agent_memory.db
MEMORY_MAX_RECENT_EXPERIENCES=50
MEMORY_MAX_LONG_TERM_MEMORIES=1000

# Device Configuration
DEVICE_CONTROLLER_TYPE=simulation
DEVICE_POLLING_INTERVAL=1.0

# Perception Configuration
PERCEPTION_CAMERA_INTERVAL=5.0
PERCEPTION_THINKING_INTERVAL=10.0

# API Configuration
API_TIMEOUT=30
API_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Web Interface Configuration
WEB_REFRESH_INTERVAL=1000